rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuários: só o próprio dono lê e escreve ─────────────────────────────
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Índices de CPF e Placa: leitura para verificar duplicatas, ────────────
    // ── escrita apenas para usuário autenticado ───────────────────────────────
    match /cpf_index/{cpf} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /placa_index/{placa} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Conversas: dono da conversa lê e escreve ─────────────────────────────
    match /conversas/{conversaId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;

      // Subcoleções: perguntas, respostas, documentos
      match /perguntas/{docId} {
        allow read, write: if request.auth != null;
      }
      match /respostas/{docId} {
        allow read, write: if request.auth != null;
      }
      match /documentos/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── FAQs aprendidos: qualquer autenticado lê, escreve ────────────────────
    match /faq_aprendido/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Tópicos: qualquer autenticado lê, escreve ────────────────────────────
    match /topicos/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
